# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Flask
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=false

# Database (use a full Neon/PostgreSQL connection string, or individual vars below)
DATABASE_URL=postgresql://user:password@host/dbname

# Admin panel credentials
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_strong_password

# Email (Gmail SMTP — use an App Password, not your account password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_DEFAULT_SENDER=your_gmail@gmail.com
ADMIN_EMAIL=aquabliss217@gmail.com
